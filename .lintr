    line_length_linter = NULL,        # matches blockr.dplyr / blockr.viz
    commented_code_linter = NULL,     # matches blockr.dplyr / blockr.viz
    indentation_linter = NULL,        # matches blockr.dplyr / blockr.viz
    brace_linter = NULL               # matches blockr.dm / blockr.ggplot
  )
